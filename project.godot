; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="LowSignal"
config/version="1.0"
run/main_scene="uid://clylocg08kwpl"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.9411765, 0.9843137, 1, 1)
boot_splash/image="uid://ctmjxxu5vxtif"
config/icon="res://icon.svg"

[debug]

settings/stdout/print_fps=true
settings/stdout/print_gpu_profile=true

[display]

window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="LowSignal"

[editor_plugins]

enabled=PackedStringArray("res://addons/proton_scatter/plugin.cfg", "res://addons/zylann.hterrain/plugin.cfg")

[filesystem]

import/blender/enabled=false


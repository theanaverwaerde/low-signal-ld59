[sub_resource type="VisualShaderNodeExpression" id="VisualShaderNodeExpression_wg4j2"]
size = Vector2(1100, 800)
expression = "vec4 world_pos = MODEL_MATRIX * vec4(VERTEX, 1.0);
vec2 uv = world_pos.xz / (NoiseScale + 1e-2);
PanningUV = uv + fract(TIME * WindDirection * WindSpeed);"

[sub_resource type="FastNoiseLite" id="FastNoiseLite_nga5s"]

